<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Magic Dreams — Event Control</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-authentication-library/3.27.0/msal-browser.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0a0a0f; --surface:#111118; --surface2:#18181f; --surface3:#1f1f28;
    --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.13);
    --gold:#f0c040; --gold2:#ffd966; --gold-dim:rgba(240,192,64,0.15); --gold-dim2:rgba(240,192,64,0.07);
    --text:#f0eff5; --text2:#9896a8; --text3:#5e5c6e;
    --red:#ff5c7a; --green:#4dffb0; --blue:#5ca8ff; --purple:#b07aff; --orange:#ff9040; --cyan:#40d4ff;
    --ms-blue:#0078d4;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:999;opacity:0.4;}
 
  /* LOGIN */
  #login-screen{position:fixed;inset:0;z-index:800;display:flex;align-items:center;justify-content:center;background:var(--bg);}
  .login-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% -10%,rgba(240,192,64,0.12) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 80% 80%,rgba(92,168,255,0.06) 0%,transparent 60%);}
  .login-lines{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
  .login-lines::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background-image:linear-gradient(rgba(240,192,64,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(240,192,64,0.04) 1px,transparent 1px);background-size:60px 60px;animation:gridShift 20s linear infinite;}
  @keyframes gridShift{to{transform:translate(60px,60px);}}
  .login-card{position:relative;z-index:2;background:var(--surface);border:1px solid var(--border2);border-radius:20px;padding:48px 44px;width:100%;max-width:440px;text-align:center;box-shadow:0 40px 80px rgba(0,0,0,0.6),0 0 0 1px rgba(240,192,64,0.05);animation:cardIn 0.5s ease;}
  @keyframes cardIn{from{transform:translateY(30px) scale(0.96);opacity:0;}to{transform:none;opacity:1;}}
  .login-logo-tag{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--gold);letter-spacing:4px;text-transform:uppercase;margin-bottom:8px;opacity:0.8;}
  .login-logo{font-family:'Bebas Neue',sans-serif;font-size:44px;letter-spacing:3px;color:var(--text);line-height:1;margin-bottom:4px;}
  .login-logo span{color:var(--gold);}
  .login-subtitle{font-size:13px;color:var(--text3);margin-bottom:36px;}
  .login-divider{display:flex;align-items:center;gap:12px;margin-bottom:28px;}
  .login-divider::before,.login-divider::after{content:'';flex:1;height:1px;background:var(--border);}
  .login-divider span{font-size:11px;color:var(--text3);letter-spacing:1px;}
  .btn-microsoft{display:flex;align-items:center;justify-content:center;gap:12px;width:100%;padding:14px 20px;background:var(--ms-blue);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.2s;}
  .btn-microsoft:hover{background:#106ebe;transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,120,212,0.4);}
  .ms-icon{width:20px;height:20px;flex-shrink:0;display:grid;grid-template-columns:1fr 1fr;gap:2px;}
  .ms-icon div{border-radius:1px;}
  .ms-icon div:nth-child(1){background:#f25022;}.ms-icon div:nth-child(2){background:#7fba00;}
  .ms-icon div:nth-child(3){background:#00a4ef;}.ms-icon div:nth-child(4){background:#ffb900;}
  .login-footer{margin-top:28px;font-size:11px;color:var(--text3);line-height:1.6;}
  .login-footer a{color:var(--gold);}
  .login-error{background:rgba(255,92,122,0.1);border:1px solid rgba(255,92,122,0.3);border-radius:8px;padding:12px 14px;font-size:12px;color:var(--red);margin-bottom:16px;text-align:left;display:none;}
  .login-loading{display:none;flex-direction:column;align-items:center;gap:16px;padding:20px 0;}
  .spinner{width:32px;height:32px;border:3px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin 0.8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .sim-box{background:var(--surface2);border:1px solid var(--border2);border-radius:12px;padding:20px;margin-bottom:14px;text-align:left;}
  .sim-label{display:flex;align-items:center;gap:8px;margin-bottom:16px;}
  .sim-label span{font-size:12px;font-weight:600;color:var(--text2);}
 
  /* PENDING */
  #pending-screen{position:fixed;inset:0;z-index:700;display:none;align-items:center;justify-content:center;background:var(--bg);}
  .pending-card{background:var(--surface);border:1px solid var(--border2);border-radius:20px;padding:48px 44px;width:100%;max-width:480px;text-align:center;animation:cardIn 0.4s ease;}
  .pending-icon{font-size:56px;margin-bottom:20px;}
  .pending-title{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:2px;color:var(--text);margin-bottom:10px;}
  .pending-sub{font-size:14px;color:var(--text2);line-height:1.7;margin-bottom:24px;}
  .pending-email{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--gold);background:var(--gold-dim);border:1px solid rgba(240,192,64,0.2);border-radius:6px;padding:8px 14px;display:inline-block;margin-bottom:24px;}
 
  /* APP */
  #app-shell{display:none;}
  .sidebar{position:fixed;top:0;left:0;bottom:0;width:240px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;}
  .logo-area{padding:28px 24px 24px;border-bottom:1px solid var(--border);}
  .logo-tag{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--gold);letter-spacing:3px;text-transform:uppercase;margin-bottom:6px;opacity:0.8;}
  .logo-name{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;color:var(--text);line-height:1;}
  .logo-name span{color:var(--gold);}
  .sidebar-nav{flex:1;padding:20px 0;overflow-y:auto;}
  .nav-section-label{font-size:10px;font-weight:600;letter-spacing:2.5px;color:var(--text3);text-transform:uppercase;padding:0 24px 8px;margin-top:12px;}
  .nav-item{display:flex;align-items:center;gap:12px;padding:10px 24px;cursor:pointer;transition:all 0.15s;color:var(--text2);font-size:14px;font-weight:400;border-left:2px solid transparent;}
  .nav-item:hover{color:var(--text);background:var(--gold-dim2);}
  .nav-item.active{color:var(--gold);background:var(--gold-dim);border-left-color:var(--gold);font-weight:500;}
  .nav-icon{width:18px;text-align:center;font-size:15px;flex-shrink:0;}
  .nav-badge{margin-left:auto;background:var(--gold);color:var(--bg);font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;font-family:'JetBrains Mono',monospace;}
  .sidebar-bottom{padding:16px;border-top:1px solid var(--border);}
  .user-pill{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--surface2);border-radius:10px;cursor:pointer;transition:background 0.15s;position:relative;}
  .user-pill:hover{background:var(--surface3);}
  .user-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--bg);flex-shrink:0;}
  .user-info{overflow:hidden;flex:1;}
  .user-name{font-size:13px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .user-role-badge{font-size:10px;white-space:nowrap;}
  .role-admin{color:var(--gold);} .role-user{color:var(--blue);}
  .user-menu{position:absolute;bottom:60px;left:0;right:0;background:var(--surface2);border:1px solid var(--border2);border-radius:10px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.5);display:none;z-index:200;}
  .user-menu.open{display:block;}
  .umi{padding:11px 14px;font-size:13px;color:var(--text2);cursor:pointer;transition:background 0.1s;display:flex;align-items:center;gap:9px;}
  .umi:hover{background:var(--surface3);color:var(--text);}
  .umi-sep{height:1px;background:var(--border);}
 
  /* MAIN */
  .main{margin-left:240px;min-height:100vh;}
  .topbar{height:64px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 32px;gap:16px;position:sticky;top:0;z-index:50;}
  .topbar-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--text);flex:1;}
  .topbar-search{position:relative;flex:1;max-width:360px;}
  .topbar-search input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 14px 8px 36px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border 0.2s;}
  .topbar-search input:focus{border-color:var(--gold);}
  .topbar-search input::placeholder{color:var(--text3);}
  .si{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:14px;}
  .btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all 0.15s;white-space:nowrap;}
  .btn-primary{background:var(--gold);color:var(--bg);} .btn-primary:hover{background:var(--gold2);transform:translateY(-1px);}
  .btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border);} .btn-ghost:hover{background:var(--surface2);color:var(--text);}
  .btn-danger{background:rgba(255,92,122,0.1);color:var(--red);border:1px solid rgba(255,92,122,0.2);} .btn-danger:hover{background:rgba(255,92,122,0.2);}
 
  /* PAGES */
  .page{display:none;padding:32px;} .page.active{display:block;}
  .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
  .section-title{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1.5px;color:var(--text);}
 
  /* KPI */
  .kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;}
  .kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:22px;position:relative;overflow:hidden;transition:border-color 0.2s,transform 0.2s;}
  .kpi-card:hover{border-color:var(--border2);transform:translateY(-2px);}
  .kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
  .kpi-card.gold::before{background:var(--gold);} .kpi-card.green::before{background:var(--green);}
  .kpi-card.blue::before{background:var(--blue);} .kpi-card.purple::before{background:var(--purple);}
  .kpi-label{font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);margin-bottom:10px;}
  .kpi-val{font-family:'Bebas Neue',sans-serif;font-size:42px;line-height:1;margin-bottom:6px;}
  .kpi-card.gold .kpi-val{color:var(--gold);} .kpi-card.green .kpi-val{color:var(--green);}
  .kpi-card.blue .kpi-val{color:var(--blue);} .kpi-card.purple .kpi-val{color:var(--purple);}
  .kpi-sub{font-size:12px;color:var(--text3);}
  .kpi-icon{position:absolute;right:18px;top:50%;transform:translateY(-50%);font-size:36px;opacity:0.07;}
  .grid-3-1{display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:24px;}
  .panel{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
  .panel-header{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;border-bottom:1px solid var(--border);}
  .panel-title{font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:1.5px;color:var(--text);}
  .panel-action{font-size:12px;color:var(--gold);cursor:pointer;font-weight:500;}
  .panel-action:hover{text-decoration:underline;}
  .panel-body{padding:20px 22px;}
  .event-row{display:flex;align-items:center;gap:14px;padding:10px 8px;margin:0 -8px;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s;border-radius:6px;}
  .event-row:last-child{border-bottom:none;} .event-row:hover{background:var(--gold-dim2);}
  .event-main{flex:1;min-width:0;}
  .event-name{font-size:13px;font-weight:500;color:var(--text);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .event-meta{font-size:11px;color:var(--text3);display:flex;gap:10px;flex-wrap:wrap;}
  .event-date-badge{background:var(--surface3);border:1px solid var(--border);border-radius:6px;padding:4px 10px;text-align:center;flex-shrink:0;min-width:58px;}
  .edb-day{font-family:'Bebas Neue',sans-serif;font-size:18px;line-height:1;color:var(--gold);}
  .edb-month{font-size:9px;letter-spacing:1px;color:var(--text3);text-transform:uppercase;}
  .status-chip{font-size:10px;font-weight:600;letter-spacing:0.5px;padding:3px 10px;border-radius:20px;flex-shrink:0;text-transform:uppercase;}
  .sc-active{background:rgba(77,255,176,0.12);color:var(--green);}
  .sc-upcoming{background:rgba(92,168,255,0.12);color:var(--blue);}
  .sc-planning{background:rgba(240,192,64,0.12);color:var(--gold);}
  .sc-done{background:rgba(158,156,168,0.1);color:var(--text3);}
  .sc-paused{background:rgba(255,92,122,0.1);color:var(--red);}
  .team-member-row{display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border);}
  .team-member-row:last-child{border-bottom:none;}
  .member-avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;color:var(--bg);}
  .member-info{flex:1;}
  .member-name{font-size:13px;font-weight:500;color:var(--text);}
  .member-role{font-size:11px;color:var(--text3);}
 
  /* EVENTS TABLE */
  .events-toolbar{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;align-items:center;}
  .filter-tabs{display:flex;background:var(--surface2);border:1px solid var(--border);border-radius:8px;overflow:hidden;flex-shrink:0;}
  .filter-tab{padding:8px 16px;font-size:12px;font-weight:500;cursor:pointer;color:var(--text2);border-right:1px solid var(--border);transition:all 0.15s;white-space:nowrap;}
  .filter-tab:last-child{border-right:none;}
  .filter-tab.active{background:var(--gold);color:var(--bg);}
  .filter-tab:not(.active):hover{background:var(--surface3);color:var(--text);}
  .type-filter{display:flex;gap:6px;flex-wrap:wrap;}
  .type-chip{padding:6px 12px;font-size:11px;font-weight:600;border-radius:20px;cursor:pointer;border:1px solid var(--border);color:var(--text2);transition:all 0.15s;background:var(--surface2);white-space:nowrap;}
  .etw{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
  .et{width:100%;border-collapse:collapse;}
  .et thead tr{background:var(--surface2);border-bottom:1px solid var(--border);}
  .et th{padding:12px 16px;font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);text-align:left;white-space:nowrap;}
  .et td{padding:14px 16px;font-size:13px;color:var(--text);border-bottom:1px solid var(--border);vertical-align:middle;}
  .et tbody tr:last-child td{border-bottom:none;}
  .et tbody tr{transition:background 0.1s;cursor:pointer;}
  .et tbody tr:hover td{background:var(--gold-dim2);}
  .type-tag{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;padding:3px 9px;border-radius:5px;white-space:nowrap;}
  .lc{display:flex;align-items:center;gap:8px;}
  .la-sm{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--bg);flex-shrink:0;}
  .assign-btn{font-size:11px;color:var(--gold);background:var(--gold-dim);border:1px dashed rgba(240,192,64,0.3);border-radius:6px;padding:4px 10px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s;}
  .assign-btn:hover{background:var(--gold-dim2);border-color:var(--gold);}
  .assign-btn-disabled{font-size:11px;color:var(--text3);background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:4px 10px;cursor:default;font-family:'DM Sans',sans-serif;}
  .pb-wrap{background:var(--surface3);border-radius:20px;height:6px;width:80px;overflow:hidden;}
  .pb-fill{height:100%;border-radius:20px;transition:width 0.5s;}
 
  /* CALENDAR */
  .calendar-wrap{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
  .cal-header{display:flex;align-items:center;gap:16px;padding:18px 22px;border-bottom:1px solid var(--border);}
  .cal-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;flex:1;}
  .cal-nav{display:flex;gap:6px;}
  .cal-nav-btn{width:32px;height:32px;border-radius:7px;background:var(--surface2);border:1px solid var(--border);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all 0.15s;}
  .cal-nav-btn:hover{background:var(--surface3);color:var(--text);}
  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);}
  .cal-dh{padding:10px;text-align:center;font-size:10px;font-weight:600;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;border-bottom:1px solid var(--border);}
  .cal-cell{min-height:90px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:8px;transition:background 0.1s;}
  .cal-cell:hover{background:var(--gold-dim2);}
  .cal-cell:nth-child(7n){border-right:none;}
  .cal-cell.om .cal-date{opacity:0.25;}
  .cal-date{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text3);margin-bottom:6px;}
  .cal-cell.today .cal-date{background:var(--gold);color:var(--bg);width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;}
  .cal-ed{font-size:10px;padding:2px 6px;border-radius:4px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;}
 
  /* TEAM */
  .team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
  .team-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px;transition:all 0.2s;position:relative;overflow:hidden;}
  .team-card:hover{border-color:var(--border2);transform:translateY(-2px);}
  .tc-top{display:flex;align-items:center;gap:14px;margin-bottom:16px;}
  .tc-avatar{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:700;color:var(--bg);flex-shrink:0;}
  .tc-name{font-size:16px;font-weight:600;color:var(--text);margin-bottom:3px;}
  .tc-role{font-size:12px;color:var(--text3);}
  .tc-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding-top:16px;border-top:1px solid var(--border);}
  .tc-sv{font-family:'Bebas Neue',sans-serif;font-size:22px;line-height:1;margin-bottom:3px;}
  .tc-sl{font-size:10px;color:var(--text3);}
  .tc-evs{margin-top:14px;display:flex;flex-direction:column;gap:5px;}
  .tc-et{font-size:11px;padding:3px 9px;border-radius:5px;display:inline-block;color:var(--text2);background:var(--surface2);border:1px solid var(--border);}
 
  /* ADMIN */
  .aut{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
  .aut table{width:100%;border-collapse:collapse;}
  .aut th{padding:12px 16px;font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);text-align:left;background:var(--surface2);border-bottom:1px solid var(--border);}
  .aut td{padding:14px 16px;font-size:13px;color:var(--text);border-bottom:1px solid var(--border);vertical-align:middle;}
  .aut tbody tr:last-child td{border-bottom:none;}
  .aut tbody tr:hover td{background:var(--gold-dim2);}
  .role-select{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:5px 10px;font-size:12px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;cursor:pointer;transition:border 0.2s;}
  .role-select:focus{border-color:var(--gold);}
  .role-select option{background:var(--surface2);}
