function renderCalendar(){
  const months=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('cal-label').textContent=`${months[calM]} ${calY}`;
  const grid=document.getElementById('cal-grid');
  const headers=grid.querySelectorAll('.cal-dh');
  grid.innerHTML=''; headers.forEach(h=>grid.appendChild(h));
  const fd=new Date(calY,calM,1).getDay();
  const dim=new Date(calY,calM+1,0).getDate();
  const dip=new Date(calY,calM,0).getDate();
  const today=new Date();
  for(let i=fd-1;i>=0;i--){const c=document.createElement('div');c.className='cal-cell om';c.innerHTML=`<div class="cal-date">${dip-i}</div>`;grid.appendChild(c);}
  for(let d=1;d<=dim;d++){
    const c=document.createElement('div');
    const isTod=today.getFullYear()===calY&&today.getMonth()===calM&&today.getDate()===d;
    c.className='cal-cell'+(isTod?' today':'');
    c.innerHTML=`<div class="cal-date">${d}</div>`;
    const ds=`${calY}-${String(calM+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    EVENTS.filter(e=>e.date===ds).forEach(e=>{
      const tc=TC[e.type]||{icon:'📌',color:'#888',bg:'#222'};
      const dot=document.createElement('div'); dot.className='cal-ed';
      dot.style.cssText=`background:${tc.bg};color:${tc.color}`;
      dot.textContent=`${tc.icon} ${e.name}`; dot.onclick=()=>openEv(e.id);
      c.appendChild(dot);
    });
    grid.appendChild(c);
  }
  const total=fd+dim, rem=total%7===0?0:7-(total%7);
  for(let d=1;d<=rem;d++){const c=document.createElement('div');c.className='cal-cell om';c.innerHTML=`<div class="cal-date">${d}</div>`;grid.appendChild(c);}
}
function changeMonth(dir){calM+=dir;if(calM>11){calM=0;calY++;}if(calM<0){calM=11;calY--;}renderCalendar();}
 
