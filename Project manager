function openEv(id){
  const e=EVENTS.find(x=>x.id===id); if(!e) return;
  const tc=TC[e.type]||{icon:'📌',color:'#888',bg:'#222'};
  const sc=SC[e.status]||{};
  const d=new Date(e.date+'T12:00:00');
  const ds=d.toLocaleDateString('es',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  const leader=e.leader?TEAM.find(t=>t.id===e.leader):null;
  const dl=Math.ceil((d-new Date())/86400000);
 
  let lSec;
  if(leader){
    const chgBtn=isAdmin()?`<button class="btn btn-ghost" style="font-size:12px" onclick="openAssign(${e.id})">Cambiar</button>`:'';
    lSec=`<div style="display:flex;align-items:center;gap:14px;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px">
      <div class="member-avatar" style="background:${leader.color};width:44px;height:44px;font-size:15px">${leader.initials}</div>
      <div style="flex:1"><div style="font-size:15px;font-weight:600">${leader.name}</div><div style="font-size:12px;color:var(--text3)">${leader.role}</div><div style="font-size:11px;color:var(--text3)">${leader.email||''}</div></div>
      ${chgBtn}
    </div>`;
  } else if(isAdmin()){
    lSec=`<div style="background:rgba(255,92,122,0.06);border:1px dashed rgba(255,92,122,0.3);border-radius:10px;padding:16px;display:flex;align-items:center;gap:12px">
      <span style="font-size:20px">⚠️</span><div style="flex:1"><div style="font-size:13px;color:var(--red);font-weight:500">Sin líder asignado</div><div style="font-size:11px;color:var(--text3)">Requiere un responsable</div></div>
      <button class="btn btn-primary" onclick="openAssign(${e.id})">Asignar Líder</button>
    </div>`;
  } else {
    lSec=`<div style="background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px;font-size:13px;color:var(--text3)">⚠️ Sin líder asignado. Solo un administrador puede realizar esta acción.</div>`;
  }
 
  const adminActs=isAdmin()?`<button class="btn btn-ghost" onclick="setEvStatus(${e.id},'active')" style="${e.status==='active'?'border-color:var(--green);color:var(--green)':''}">✓ Activo</button><button class="btn btn-ghost" onclick="setEvStatus(${e.id},'done')">✓ Finalizar</button><div style="flex:1"></div><button class="btn btn-danger" onclick="deleteEv(${e.id})">🗑</button>`:'';
 
  document.getElementById('ev-modal-content').innerHTML=`
    <div class="mh">
      <div class="mti" style="background:${tc.bg}">${tc.icon}</div>
      <div class="mht">
        <div class="men">${e.name}</div>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
          <span class="status-chip ${sc.cls}">${sc.label}</span>
          <span class="type-tag" style="background:${tc.bg};color:${tc.color}">${tc.icon} ${e.type}</span>
          ${dl>=0&&e.status!=='done'?`<span style="font-size:11px;color:${dl<=7?'var(--red)':'var(--text3)'}">⏱ ${dl===0?'HOY':dl+'d restantes'}</span>`:''}
        </div>
      </div>
      <div class="mc" onclick="closeModal('ev-modal')">✕</div>
    </div>
    <div class="mb">
      <div class="mg">
        <div class="mf"><div class="mfl">Fecha</div><div class="mfv">${ds}</div></div>
        <div class="mf"><div class="mfl">Hora</div><div class="mfv">${e.time||'—'}</div></div>
        <div class="mf"><div class="mfl">Aforo</div><div class="mfv">${e.capacity?Number(e.capacity).toLocaleString()+' personas':'—'}</div></div>
        <div class="mf" style="grid-column:1/-1"><div class="mfl">Venue</div><div class="mfv">📍 ${e.venue||'—'}</div></div>
        <div class="mf" style="grid-column:1/-1">
          <div class="mfl">Progreso</div>
          <div style="display:flex;align-items:center;gap:12px;margin-top:6px">
            <div style="flex:1;background:var(--surface3);border-radius:20px;height:8px;overflow:hidden"><div style="width:${e.progress}%;height:100%;background:${tc.color};border-radius:20px"></div></div>
            <span style="font-family:'JetBrains Mono',monospace;font-size:14px;color:${tc.color};font-weight:700">${e.progress}%</span>
          </div>
        </div>
      </div>
      <div class="mst">LÍDER RESPONSABLE</div>
      ${lSec}
      ${e.notes?`<div class="mst">NOTAS</div><div class="mnotes">${e.notes}</div>`:''}
      <div class="ma">${adminActs}<button class="btn btn-ghost" onclick="closeModal('ev-modal')" style="${!isAdmin()?'margin-left:auto':''}">Cerrar</button></div>
    </div>`;
  document.getElementById('ev-modal').classList.add('open');
}
 
function openAssign(evId){
  if(!isAdmin()){ showToast('⛔ Solo administradores pueden asignar líderes','error'); return; }
  closeModal('ev-modal');
  const e=EVENTS.find(x=>x.id===evId);
  document.getElementById('ev-modal-content').innerHTML=`
    <div class="mh"><div class="mti" style="background:var(--gold-dim)">👤</div><div class="mht"><div class="men">ASIGNAR LÍDER</div><div style="font-size:13px;color:var(--text3)">${e?.name}</div></div><div class="mc" onclick="closeModal('ev-modal')">✕</div></div>
    <div class="mb"><div style="display:flex;flex-direction:column;gap:10px">
      ${TEAM.map(m=>{
        const cnt=EVENTS.filter(ev=>ev.leader===m.id&&ev.status!=='done').length;
        const isAss=e?.leader===m.id;
        return `<div onclick="assignLeader(${evId},${m.id})" style="display:flex;align-items:center;gap:14px;padding:14px;background:${isAss?'var(--gold-dim)':'var(--surface2)'};border:1px solid ${isAss?'var(--gold)':'var(--border)'};border-radius:10px;cursor:pointer;transition:all 0.15s">
          <div class="member-avatar" style="background:${m.color};width:42px;height:42px;font-size:15px">${m.initials}</div>
          <div style="flex:1"><div style="font-size:14px;font-weight:600">${m.name}</div><div style="font-size:12px;color:var(--text3)">${m.role} · ${cnt} eventos activos</div></div>
          ${isAss?'<span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;background:var(--gold);color:var(--bg)">ASIGNADO</span>':''}
        </div>`;
      }).join('')}
      <div onclick="assignLeader(${evId},null)" style="display:flex;align-items:center;gap:14px;padding:12px;background:var(--surface2);border:1px solid var(--border);border-radius:10px;cursor:pointer">
        <div style="width:42px;height:42px;border-radius:50%;background:var(--surface3);display:flex;align-items:center;justify-content:center;font-size:18px">✕</div>
        <div style="font-size:13px;color:var(--text3)">Sin asignar (quitar líder)</div>
      </div>
    </div></div>`;
  document.getElementById('ev-modal').classList.add('open');
}
 
function assignLeader(evId,lid){
  if(!isAdmin()) return;
  const e=EVENTS.find(x=>x.id===evId); if(e) e.leader=lid;
  const l=lid?TEAM.find(t=>t.id===lid):null;
  showToast(lid?`✓ ${l.name} asignado a "${e.name}"`:`Líder removido de "${e.name}"`);
  closeModal('ev-modal'); refresh(); updateBadge();
}
 
function setEvStatus(id,status){
  if(!isAdmin()) return;
  const e=EVENTS.find(x=>x.id===id); if(e){e.status=status;if(status==='done')e.progress=100;}
  showToast(`Estado: ${SC[status]?.label}`); closeModal('ev-modal'); refresh(); updateBadge();
}
 
function deleteEv(id){
  if(!isAdmin()) return;
  const e=EVENTS.find(x=>x.id===id);
  if(!confirm(`¿Eliminar "${e?.name}"?`)) return;
  EVENTS=EVENTS.filter(x=>x.id!==id);
  closeModal('ev-modal'); showToast('🗑 Evento eliminado'); refresh(); updateBadge();
}
 
// ============================================================
// NEW EVENT / MEMBER (admin only)
// ============================================================
function openNewEvent(){
  if(!isAdmin()){showToast('⛔ Solo administradores pueden crear eventos','error');return;}
  const s=document.getElementById('ne-leader');
  s.innerHTML='<option value="">Sin asignar</option>'+TEAM.map(m=>`<option value="${m.id}">${m.name} — ${m.role}</option>`).join('');
  document.getElementById('ne-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('new-ev-modal').classList.add('open');
}
 
function createEvent(){
  if(!isAdmin()) return;
  const name=document.getElementById('ne-name').value.trim();
  const type=document.getElementById('ne-type').value;
  const date=document.getElementById('ne-date').value;
  if(!name||!type||!date){showToast('⚠ Nombre, tipo y fecha requeridos','error');return;}
  const newId=Math.max(...EVENTS.map(e=>e.id),0)+1;
  EVENTS.push({id:newId,name,type,status:document.getElementById('ne-status').value,date,time:document.getElementById('ne-time').value,venue:document.getElementById('ne-venue').value.trim(),leader:document.getElementById('ne-leader').value?parseInt(document.getElementById('ne-leader').value):null,notes:document.getElementById('ne-notes').value.trim(),capacity:document.getElementById('ne-cap').value?parseInt(document.getElementById('ne-cap').value):null,progress:parseInt(document.getElementById('ne-prog').value)||0});
  closeModal('new-ev-modal');showToast(`✓ "${name}" creado`);
  ['ne-name','ne-type','ne-time','ne-venue','ne-notes','ne-cap'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('ne-prog').value='0';document.getElementById('ne-status').value='planning';
  refresh();updateBadge();
}
 
function openNewMember(){
  if(!isAdmin()){showToast('⛔ Solo administradores pueden agregar miembros','error');return;}
  document.getElementById('new-mb-modal').classList.add('open');
}
 
function createMember(){
  if(!isAdmin()) return;
  const name=document.getElementById('nm-name').value.trim();
  const role=document.getElementById('nm-role').value.trim();
  if(!name||!role){showToast('⚠ Nombre y cargo requeridos','error');return;}
  const initials=name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();
  const color=COLORS[TEAM.length%COLORS.length];
  const newId=Math.max(...TEAM.map(t=>t.id),0)+1;
  TEAM.push({id:newId,name,role,email:document.getElementById('nm-email').value.trim(),phone:document.getElementById('nm-phone').value.trim(),initials,color,specialties:document.getElementById('nm-spec').value?document.getElementById('nm-spec').value.split(',').map(s=>s.trim()):[]});
  closeModal('new-mb-modal');showToast(`✓ ${name} agregado`);
  ['nm-name','nm-role','nm-email','nm-phone','nm-spec'].forEach(id=>document.getElementById(id).value='');
  renderTeam();
}
 
// ============================================================
// UTILS
// ============================================================
function closeModal(id){document.getElementById(id).classList.remove('open');}
function showToast(msg,type='success'){
  const c=document.getElementById('tc');const t=document.createElement('div');
  t.className='toast'+(type==='error'?' error':'');if(type==='error')t.style.borderLeftColor='var(--red)';
  t.textContent=msg;c.appendChild(t);
  setTimeout(()=>{t.style.animation='toastOut 0.3s ease forwards';setTimeout(()=>t.remove(),300);},3000);
}
function toggleMenu(){document.getElementById('user-menu').classList.toggle('open');}
document.addEventListener('click',e=>{if(!e.target.closest('.sidebar-bottom'))document.getElementById('user-menu')?.classList.remove('open');});
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');}));
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.modal-overlay.open').forEach(m=>m.classList.remove('open'));});
 
// INIT
initApp();
</script>
</body>
</html>