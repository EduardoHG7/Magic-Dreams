async function initApp(){
  if(!SIMULATE_AUTH){
    try{
      msalApp=new msal.PublicClientApplication(MSAL_CONFIG);
      await msalApp.initialize();
      const r=await msalApp.handleRedirectPromise();
      if(r){ handleMSProfile({id:r.account.homeAccountId,name:r.account.name,email:r.account.username}); return; }
    }catch(e){ console.error('MSAL error:',e); }
  }
  const saved=loadSess();
  if(saved){
    const fresh=USERS.find(u=>u.id===saved.id);
    if(fresh){ CU=fresh; saveSess(CU); fresh.role==='pending'?showPending():enterApp(); return; }
  }
  document.getElementById('login-screen').style.display='flex';
}
 
async function loginWithMicrosoft(){
  document.getElementById('login-error').style.display='none';
  document.getElementById('login-form-area').style.display='none';
  document.getElementById('login-loading').style.display='flex';
 
  if(SIMULATE_AUTH){ showSimLogin(); return; }
 
  try{
