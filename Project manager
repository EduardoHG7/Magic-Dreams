function handleMSProfile(p){
  let u=USERS.find(x=>x.email===p.email);
  if(!u){
    const initials=p.name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();
    u={id:p.id,name:p.name,email:p.email,role:'pending',initials,color:COLORS[USERS.length%COLORS.length],lastSeen:new Date().toISOString()};
    USERS.push(u); saveUsers();
  } else {
    u.lastSeen=new Date().toISOString();
    if(p.name) u.name=p.name;
    saveUsers();
  }
  CU=u; saveSess(CU);
  u.role==='pending'?showPending():enterApp();
}
 
